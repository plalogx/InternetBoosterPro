<Window x:Class="InternetBoosterPro.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Internet Booster Pro" Height="520" Width="760" MinHeight="420" MinWidth="700">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Vertical" Grid.Row="0">
            <TextBlock FontSize="18" FontWeight="Bold" Text="MTProto Proxy" Margin="0,0,0,8" />
            <WrapPanel Margin="0,0,0,6" VerticalAlignment="Center">
                <TextBlock Text="Local port:" VerticalAlignment="Center" />
                <TextBox x:Name="PortTextBox" Width="80" Margin="6,0,0,0" Text="1443" />
                <TextBlock Text="Secret:" Margin="16,0,0,0" VerticalAlignment="Center" />
                <TextBox x:Name="SecretTextBox" Width="320" Margin="6,0,0,0" TextChanged="SecretTextBox_TextChanged" />
            </WrapPanel>
            <WrapPanel Margin="0,0,0,8">
                <Button x:Name="GenerateSecretButton" Content="Generate secret" Click="GenerateSecretButton_Click" Width="140" />
                <Button x:Name="StartStopButton" Content="Start proxy" Click="StartStopButton_Click" Width="140" Margin="8,0,0,0" />
                <Button x:Name="CopyLinkButton" Content="Copy tg://proxy link" Click="CopyLinkButton_Click" Width="170" Margin="8,0,0,0" />
            </WrapPanel>
            <TextBlock x:Name="ProxyLinkTextBlock" TextWrapping="Wrap" Foreground="Gray" Margin="0,4,0,0" />
            <TextBlock Text="Используйте этот секрет в Telegram MTProto proxy: сервер 127.0.0.1, порт 1443." TextWrapping="Wrap" Foreground="#FF333333" Margin="0,6,0,0" />
        </StackPanel>

        <Border Grid.Row="1" BorderBrush="#FFCCCCCC" BorderThickness="1" Padding="8" Margin="0,0,0,8">
            <TextBlock FontWeight="SemiBold" Text="Proxy status and logs:" />
        </Border>

        <TextBox x:Name="LogTextBox" Grid.Row="2" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" AcceptsReturn="True" IsReadOnly="True" />
    </Grid>
</Window>
